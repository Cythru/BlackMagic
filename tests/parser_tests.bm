/// BlackMagic Compiler — Parser Tests

#[cfg(test)]
mod parser_tests {
    use blackmagic::lexer::Lexer;
    use blackmagic::parser::Parser;
    use blackmagic::ast::*;

    fn parse(src: &str) -> (SourceFile, Vec<blackmagic::error::BmError>) {
        let (tokens, _) = Lexer::new(src).tokenise();
        Parser::new(tokens).parse()
    }

    fn parse_ok(src: &str) -> SourceFile {
        let (file, errors) = parse(src);
        assert!(errors.is_empty(), "unexpected parse errors: {:?}", errors);
        file
    }

    // ── Function declarations ─────────────────────────────────────────────────

    #[test]
    fn test_simple_fn() {
        let file = parse_ok("fn add(a: i32, b: i32) -> i32 { a + b }");
        assert_eq!(file.items.len(), 1);
        assert!(matches!(file.items[0].kind, ItemKind::Function(_)));
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert_eq!(f.name.name, "add");
            assert_eq!(f.params.len(), 2);
            assert!(f.ret.is_some());
        }
    }

    #[test]
    fn test_fn_no_return() {
        let file = parse_ok("fn hello() { }");
        assert!(matches!(file.items[0].kind, ItemKind::Function(_)));
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert_eq!(f.name.name, "hello");
            assert!(f.ret.is_none());
        }
    }

    #[test]
    fn test_fn_with_effects() {
        let file = parse_ok("fn read_file(path: str) -> str !IO { }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert!(!f.effects.is_empty());
            assert_eq!(f.effects[0].path.segments[0].name, "IO");
        }
    }

    #[test]
    fn test_fn_multiple_effects() {
        let file = parse_ok("fn run() !IO + Rand + Log { }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert_eq!(f.effects.len(), 3);
        }
    }

    #[test]
    fn test_comptime_fn() {
        let file = parse_ok("comptime fn pow(b: u64, e: u64) -> u64 { 1 }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert!(f.is_comptime);
        }
    }

    #[test]
    fn test_async_fn() {
        let file = parse_ok("async fn fetch(url: str) -> str !IO { }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert!(f.is_async);
        }
    }

    // ── Struct declarations ───────────────────────────────────────────────────

    #[test]
    fn test_struct_named() {
        let file = parse_ok("struct Point { x: f64, y: f64 }");
        assert!(matches!(file.items[0].kind, ItemKind::Struct(_)));
        if let ItemKind::Struct(ref s) = file.items[0].kind {
            assert_eq!(s.name.name, "Point");
            assert_eq!(s.fields.len(), 2);
        }
    }

    #[test]
    fn test_struct_tuple() {
        let file = parse_ok("struct Pair(i32, i32);");
        if let ItemKind::Struct(ref s) = file.items[0].kind {
            assert_eq!(s.fields.len(), 2);
            assert!(matches!(s.kind, StructKind::Tuple));
        }
    }

    #[test]
    fn test_struct_unit() {
        let file = parse_ok("struct Unit;");
        if let ItemKind::Struct(ref s) = file.items[0].kind {
            assert!(matches!(s.kind, StructKind::Unit));
        }
    }

    #[test]
    fn test_linear_struct() {
        let file = parse_ok("linear struct File { fd: i32 }");
        if let ItemKind::Struct(ref s) = file.items[0].kind {
            assert!(matches!(s.kind, StructKind::Linear));
        }
    }

    // ── Enum declarations ─────────────────────────────────────────────────────

    #[test]
    fn test_enum_variants() {
        let file = parse_ok(r#"
            enum Color {
                Red,
                Green,
                Blue,
            }
        "#);
        if let ItemKind::Enum(ref e) = file.items[0].kind {
            assert_eq!(e.variants.len(), 3);
            assert_eq!(e.variants[0].name.name, "Red");
        }
    }

    #[test]
    fn test_enum_tuple_variant() {
        let file = parse_ok("enum Option { Some(i32), None }");
        if let ItemKind::Enum(ref e) = file.items[0].kind {
            assert!(matches!(e.variants[0].payload, VariantPayload::Tuple(_)));
            assert!(matches!(e.variants[1].payload, VariantPayload::Unit));
        }
    }

    // ── Trait declarations ────────────────────────────────────────────────────

    #[test]
    fn test_trait_basic() {
        let file = parse_ok(r#"
            trait Display {
                fn fmt(self: &Self) -> str
            }
        "#);
        assert!(matches!(file.items[0].kind, ItemKind::Trait(_)));
        if let ItemKind::Trait(ref t) = file.items[0].kind {
            assert_eq!(t.name.name, "Display");
            assert_eq!(t.assoc.len(), 1);
        }
    }

    // ── Impl blocks ───────────────────────────────────────────────────────────

    #[test]
    fn test_impl_inherent() {
        // Simplified: no struct shorthand literal to avoid ambiguity
        let file = parse_ok(r#"
            impl Point {
                fn dist(self: &Point) -> f64 { 0.0 }
            }
        "#);
        assert!(matches!(file.items[0].kind, ItemKind::Impl(_)));
    }

    // ── Module declarations ───────────────────────────────────────────────────

    #[test]
    fn test_module() {
        let file = parse_ok(r#"
            module math {
                pub fn add(a: i32, b: i32) -> i32 { a + b }
            }
        "#);
        assert!(matches!(file.items[0].kind, ItemKind::Module(_)));
        if let ItemKind::Module(ref m) = file.items[0].kind {
            assert_eq!(m.name.name, "math");
            assert_eq!(m.items.len(), 1);
        }
    }

    // ── Effect declarations ───────────────────────────────────────────────────

    #[test]
    fn test_effect_decl() {
        // BlackMagic uses `var` for mutable refs, not `mut`
        let file = parse_ok(r#"
            effect IO {
                fn write(data: &[u8]) -> usize
                fn read(buf: &var [u8]) -> usize
            }
        "#);
        assert!(matches!(file.items[0].kind, ItemKind::Effect(_)));
        if let ItemKind::Effect(ref e) = file.items[0].kind {
            assert_eq!(e.name.name, "IO");
            assert_eq!(e.ops.len(), 2);
        }
    }

    // ── Actor declarations ────────────────────────────────────────────────────

    #[test]
    fn test_actor_decl() {
        let file = parse_ok(r#"
            actor Counter {
                var count: i64 = 0
                receive {
                    .Inc => { count += 1 },
                }
            }
        "#);
        assert!(matches!(file.items[0].kind, ItemKind::Actor(_)));
    }

    // ── Use declarations ──────────────────────────────────────────────────────

    #[test]
    fn test_use_simple() {
        let file = parse_ok("use std::io;");
        assert!(matches!(file.items[0].kind, ItemKind::Use(_)));
    }

    #[test]
    fn test_use_group() {
        let file = parse_ok("use std::io::{println, readln};");
        if let ItemKind::Use(ref u) = file.items[0].kind {
            assert!(matches!(u.tree, UseTree::Path { .. }));
        }
    }

    // ── Const / Static ────────────────────────────────────────────────────────

    #[test]
    fn test_const_decl() {
        let file = parse_ok("const MAX: u32 = 65535;");
        assert!(matches!(file.items[0].kind, ItemKind::Const { .. }));
    }

    #[test]
    fn test_static_decl() {
        let file = parse_ok("static COUNTER: u64 = 0;");
        assert!(matches!(file.items[0].kind, ItemKind::Static { .. }));
    }

    // ── Expressions ───────────────────────────────────────────────────────────

    #[test]
    fn test_if_else() {
        let file = parse_ok("fn f(x: i32) -> i32 { if x > 0 { 1 } else { -1 } }");
        assert!(matches!(file.items[0].kind, ItemKind::Function(_)));
    }

    #[test]
    fn test_match_expr() {
        let file = parse_ok(r#"
            fn classify(n: i32) -> str {
                match n {
                    0 => "zero",
                    _ => "other",
                }
            }
        "#);
        assert!(file.items.len() > 0);
    }

    #[test]
    fn test_closure() {
        let file = parse_ok("fn f() { let sq = fn(x: i32) -> i32 { x * x }; }");
        assert!(file.items.len() > 0);
    }

    #[test]
    fn test_defer() {
        let file = parse_ok("fn f() !IO { defer cleanup(); }");
        assert!(file.items.len() > 0);
    }

    #[test]
    fn test_handle_expression() {
        // Handler params need type annotations in BlackMagic
        let file = parse_ok(r#"
            fn main() {
                let result = handle compute() with {
                    IO::write(data: &[u8]) => { resume(0) },
                }
            }
        "#);
        assert!(file.items.len() > 0);
    }

    // ── Types ────────────────────────────────────────────────────────────────

    #[test]
    fn test_reference_types() {
        // Note: `borrow` is a keyword in BlackMagic; use `inspect` instead
        let file = parse_ok("fn inspect(x: &i32) -> &i32 { x }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert_eq!(f.params.len(), 1);
            assert!(matches!(f.params[0].ty, Type::Ref { mutable: false, .. }));
        }
    }

    #[test]
    fn test_mut_ref() {
        // BlackMagic uses `var` keyword for mutability, not `mut`
        let file = parse_ok("fn mutate(x: &var i32) { }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert!(matches!(f.params[0].ty, Type::Ref { mutable: true, .. }));
        }
    }

    #[test]
    fn test_optional_type() {
        let file = parse_ok("fn get() -> ?i32 { null }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert!(matches!(f.ret, Some(Type::Optional(_))));
        }
    }

    #[test]
    fn test_slice_type() {
        let file = parse_ok("fn sum(xs: &[f64]) -> f64 { 0.0 }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert!(matches!(f.params[0].ty, Type::Ref { .. }));
        }
    }

    #[test]
    fn test_owned_type() {
        let file = parse_ok("fn consume(s: owned str) { }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert!(matches!(f.params[0].ty, Type::Owned(_)));
        }
    }

    // ── Visibility ───────────────────────────────────────────────────────────

    #[test]
    fn test_pub_fn() {
        let file = parse_ok("pub fn exported() -> i32 { 42 }");
        assert!(matches!(file.items[0].vis, Visibility::Public));
    }

    // ── Error recovery ────────────────────────────────────────────────────────

    #[test]
    fn test_error_recovery() {
        let (file, errors) = parse("fn broken { ??? } fn ok() { }");
        // Should still parse fn ok despite error in fn broken
        assert!(!errors.is_empty());
        // Recovery allows parsing to continue
    }

    // ── Generics ─────────────────────────────────────────────────────────────

    #[test]
    fn test_generic_fn() {
        let file = parse_ok("fn max<T>(a: T, b: T) -> T { a }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert_eq!(f.generics.len(), 1);
            // where clause is optional — tested separately
        }
    }

    #[test]
    fn test_generic_fn_where() {
        // Where clause parsed into FunctionDecl
        let file = parse_ok("fn largest<T>(list: &[T]) -> &T where T: Ord { list }");
        if let ItemKind::Function(ref f) = file.items[0].kind {
            assert_eq!(f.generics.len(), 1);
            assert!(!f.where_.is_empty(), "where clause should be present");
        }
    }

    #[test]
    fn test_generic_struct() {
        let file = parse_ok("struct Pair<A, B> { first: A, second: B }");
        if let ItemKind::Struct(ref s) = file.items[0].kind {
            assert_eq!(s.generics.len(), 2);
        }
    }
}