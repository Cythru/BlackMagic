/// BlackMagic Engine — city/theme.bm
///
/// Oracle City — 5 visual themes.
///
/// Themes:
///   0  Midnight  — dark greys + midnight purples  (default)
///   1  Neon      — electric cyan + acid green on black
///   2  Blood     — deep crimson + rose on near-black
///   3  Amber     — terminal amber on dark brown-black
///   4  Ghost     — pale steel-blue on deep charcoal
///
/// Press T in-game to cycle through themes.

use engine::core::math::{ Color };

// ─── Theme ────────────────────────────────────────────────────────────────────

pub struct Theme {
    pub name:         str,

    // Backgrounds
    pub bg:           Color,   // clear / sky colour
    pub panel_bg:     Color,   // modal / info panel background
    pub hud_bar:      Color,   // stats bar, minimap bg strip

    // Borders + structure
    pub border:       Color,   // panel outlines, minimap frame
    pub divider:      Color,   // thin separator lines

    // Foreground
    pub text:         Color,   // primary readable text
    pub dim:          Color,   // secondary / hints
    pub accent:       Color,   // primary accent (titles, highlights)
    pub accent2:      Color,   // secondary accent (direction arrow, values)

    // Semantic colours
    pub col_green:    Color,   // money, active/ok
    pub col_yellow:   Color,   // corp, warnings
    pub col_red:      Color,   // gang, danger, north compass
    pub col_magenta:  Color,   // aug, special

    // Map colours
    pub player_dot:   Color,
    pub player_dir:   Color,
    pub map_floor:    Color,
    pub map_fov:      Color,
}

// ─── 5 Themes ─────────────────────────────────────────────────────────────────

