// ─── Theme table + cycle helper ───────────────────────────────────────────────

pub const N_THEMES: u32 = 5;

/// Get a theme by index (0–4). Wraps around.
pub fn theme_get(idx: u32) -> &Theme {
    let i = idx % N_THEMES;
    match i {
        0 => &THEME_MIDNIGHT,
        1 => &THEME_NEON,
        2 => &THEME_BLOOD,
        3 => &THEME_AMBER,
        _ => &THEME_GHOST,
    }
}
