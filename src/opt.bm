}

// ─── Vectorization Hint ───────────────────────────────────────────────────
/// Tags loops that are vectorizable (for codegen to emit SIMD).

pub struct VectorizationHint;

impl OptPass for VectorizationHint {
    fn name(&self) -> &'static str { "vec-hint" }

    fn run(&self, _func: &mut MirFunction) -> bool {
        // Walk back-edges, check for:
        //   - Simple induction variable
        //   - No loop-carried dependencies
        //   - Body is a single basic block with only arithmetic
        // If all conditions met, annotate loop header with VectorHint metadata
        false
    }
}