// ─── Inliner ──────────────────────────────────────────────────────────────

pub struct Inliner { pub threshold: usize }

impl OptPass for Inliner {
    fn name(&self) -> &'static str { "inline" }

    fn run(&self, func: &mut MirFunction) -> bool {
        // Inline call sites where callee instruction count < threshold.
        // Requires access to the full module — handled at module level.
        // Skeleton: scan for Call terminators, check callee size, splice blocks.
        let _ = self.threshold;
        false
    }
}

pub struct AggressiveInliner;
impl OptPass for AggressiveInliner {
    fn name(&self) -> &'static str { "inline-aggressive" }
    fn run(&self, _func: &mut MirFunction) -> bool { false }
}

// ─── Tail Call Elimination ────────────────────────────────────────────────

pub struct TailCallElimination;

impl OptPass for TailCallElimination {
    fn name(&self) -> &'static str { "tce" }

    fn run(&self, func: &mut MirFunction) -> bool {
        let mut changed = false;
        let fname = func.name.clone();
        let entry = func.entry;

        for block in func.blocks.iter_mut() {
            if let Terminator::Call { func: Operand::Func(callee), args, dest, .. } = &block.terminator {
                // Self-recursive tail call → Goto(entry) with arg rebinds
                if *callee == fname {
                    let new_args = args.clone();
                    // Rewrite: assign args to param slots, jump to entry
                    let stmts: Vec<MirStmt> = new_args.into_iter().enumerate().map(|(i, a)| {
                        MirStmt {
                            kind: MirStmtKind::Assign {
                                dest:  MirPlace::Local(Local(i as u32)),
                                value: Rvalue::Use(a),
                            },
                            span: crate::error::Span::default(),
                        }
                    }).collect();
                    block.stmts.extend(stmts);
                    block.terminator = Terminator::Goto { target: entry };
                    changed = true;
                }
            }
        }
        changed
    }
}

// ─── Copy Propagation ─────────────────────────────────────────────────────

pub struct CopyPropagation;

impl OptPass for CopyPropagation {
    fn name(&self) -> &'static str { "copy-prop" }

    fn run(&self, func: &mut MirFunction) -> bool {
        let mut copies: HashMap<Local, Operand> = HashMap::new();
        let mut changed = false;

        for block in func.blocks.iter_mut() {
            for stmt in block.stmts.iter_mut() {
                if let MirStmtKind::Assign { dest: MirPlace::Local(d), value: Rvalue::Use(op) } = &stmt.kind {
                    copies.insert(*d, op.clone());
                }
                changed |= substitute_consts_in_stmt(stmt, &copies.iter()
                    .filter_map(|(k, v)| if let Operand::Const(c) = v { Some((*k, c.clone())) } else { None })
                    .collect());
            }
        }
        changed
    }
}

